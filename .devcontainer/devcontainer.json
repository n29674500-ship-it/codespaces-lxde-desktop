{
  "name": "LXDE Desktop Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y lxde-core lxde-common firefox",
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "LXDE Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "vscode"
}
